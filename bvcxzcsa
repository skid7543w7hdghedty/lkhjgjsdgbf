-- Drag
local dragging = false
local dragStart = nil
local startPos = nil
local hasDragged = false
local dragInputObject = nil
local DRAG_THRESHOLD = 6

local function startDrag(input)
 if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
  dragging = true
  hasDragged = false
  dragStart = input.Position
  dragInputObject = input
  startPos = mainFrame.Position

  local connection
  connection = input.Changed:Connect(function()
   if input.UserInputState == Enum.UserInputState.End then
    dragging = false
    dragInputObject = nil
    connection:Disconnect()
   end
  end)
 end
end

mainFrame.InputBegan:Connect(startDrag)
shootButton.InputBegan:Connect(startDrag)

UserInputService.InputChanged:Connect(function(input)
 if not dragging then return end
 if input ~= dragInputObject then return end
 if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end

 local delta = input.Position - dragStart
 if not hasDragged and delta.Magnitude >= DRAG_THRESHOLD then
  hasDragged = true
 end
 if hasDragged then
  mainFrame.Position = UDim2.new(
   startPos.X.Scale,
   startPos.X.Offset + delta.X,
   startPos.Y.Scale,
   startPos.Y.Offset + delta.Y
  )
 end
end)

-- Стрельба
shootButton.MouseButton1Click:Connect(function()
 if hasDragged then return end

 if findSheriff() ~= player then
  game.StarterGui:SetCore("SendNotification", {
   Title = "Error",
   Text = "You're not sheriff/hero.",
   Duration = 2
  })
  return
 end

 local murderer = findMurderer() or findNearestPlayer()
 if not murderer then
  game.StarterGui:SetCore("SendNotification", {
   Title = "Error",
   Text = "No murderer (or other player) to shoot.",
   Duration = 2
  })
  return
 end

 if not player.Character:FindFirstChild("Gun") then
  local hum = player.Character:FindFirstChild("Humanoid")
  if player.Backpack:FindFirstChild("Gun") then
   hum:EquipTool(player.Backpack:FindFirstChild("Gun"))
  else
   game.StarterGui:SetCore("SendNotification", {
    Title = "Error",
    Text = "You don't have the gun.",
    Duration = 2
   })
   return
  end
 end

 local torso = murderer.Character:FindFirstChild("Torso")
  or murderer.Character:FindFirstChild("UpperTorso")
 if not torso then
  game.StarterGui:SetCore("SendNotification", {
   Title = "Error",
   Text = "Could not find the target's torso.",
   Duration = 2
  })
  return
 end

 -- 100% точное попадание прямо в точку (центр торса)
 local targetPosition = torso.Position

 local originPosition = player.Character:FindFirstChild("RightHand")
  and player.Character.RightHand.Position
  or player.Character.HumanoidRootPart.Position

 local args = {
  CFrame.new(originPosition),
  CFrame.new(targetPosition)
 }

 pcall(function()
  player.Character:WaitForChild("Gun"):WaitForChild("Shoot"):FireServer(unpack(args))
 end)

 game.StarterGui:SetCore("SendNotification", {
  Title = "Shot Fired",
  Text = "100% accurate shot at red dot!",
  Duration = 1.5
 })
end)

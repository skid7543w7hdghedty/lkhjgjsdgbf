-- Shoot Murderer (100% Accuracy with Red Dot)
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local targetDot = nil

local function findMurderer()
 for _, i in ipairs(Players:GetPlayers()) do
  if i.Backpack:FindFirstChild("Knife") then return i end
 end
 for _, i in ipairs(Players:GetPlayers()) do
  if not i.Character then continue end
  if i.Character:FindFirstChild("Knife") then return i end
 end
 return nil
end

local function findSheriff()
 for _, i in ipairs(Players:GetPlayers()) do
  if i.Backpack:FindFirstChild("Gun") then return i end
 end
 for _, i in ipairs(Players:GetPlayers()) do
  if not i.Character then continue end
  if i.Character:FindFirstChild("Gun") then return i end
 end
 return nil
end

local function findNearestPlayer()
 local nearestPlayer = nil
 local shortestDistance = math.huge
 for _, playerIter in ipairs(Players:GetPlayers()) do
  if playerIter ~= player and playerIter.Character then
   local localRootPart = player.Character:FindFirstChild("HumanoidRootPart")
   local otherRootPart = playerIter.Character:FindFirstChild("HumanoidRootPart")
   if localRootPart and otherRootPart then
    local distance = (localRootPart.Position - otherRootPart.Position).Magnitude
    if distance < shortestDistance then
     shortestDistance = distance
     nearestPlayer = playerIter
    end
   end
  end
 end
 return nearestPlayer
end

-- Создание маленькой красной точки на торсе (фиксированный размер 8x8)
local function createTargetDot()
 if targetDot then
  targetDot:Destroy()
 end

 local billboard = Instance.new("BillboardGui")
 billboard.Name = "TargetDot"
 billboard.AlwaysOnTop = true
 billboard.Size = UDim2.new(0, 8, 0, 8)        -- 8x8 пикселей, всегда
 billboard.SizeOffset = Vector2.new(0, 0)
 billboard.StudsOffset = Vector3.new(0, 0, 0)
 billboard.MaxDistance = math.huge
 billboard.ClipsDescendants = false

 local dot = Instance.new("Frame")
 dot.Size = UDim2.new(1, 0, 1, 0)
 dot.Position = UDim2.new(0, 0, 0, 0)
 dot.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
 dot.BorderSizePixel = 0
 dot.Parent = billboard

 local corner = Instance.new("UICorner")
 corner.CornerRadius = UDim.new(1, 0)
 corner.Parent = dot

 targetDot = billboard
 return billboard
end

-- Обновление позиции точки каждый кадр
local function updateTargetDot()
 local murderer = findMurderer()
 if murderer and murderer.Character then
  local torso = murderer.Character:FindFirstChild("Torso")
   or murderer.Character:FindFirstChild("UpperTorso")
  if torso then
   if not targetDot or not targetDot.Parent then
    createTargetDot()
    targetDot.Parent = torso
   elseif targetDot.Parent ~= torso then
    targetDot.Parent = torso
   end
  else
   if targetDot then
    targetDot:Destroy()
    targetDot = nil
   end
  end
 else
  if targetDot then
   targetDot:Destroy()
   targetDot = nil
  end
 end
end

RunService.RenderStepped:Connect(updateTargetDot)

